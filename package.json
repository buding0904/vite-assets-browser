{
  "name": "vite-assets-browser",
  "version": "0.1.0",
  "description": "A Vite plugin that launches a local asset browser UI during development — browse images, videos, and fonts with a dark-themed grid interface",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "bin": {
    "vite-assets-browser": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "vite",
    "plugin",
    "assets",
    "browser",
    "devtools",
    "svg",
    "images"
  ],
  "author": "",
  "license": "MIT",
  "peerDependencies": {
    "vite": ">=4.0.0"
  },
  "dependencies": {
    "fast-glob": "^3.3.2"
  },
  "devDependencies": {
    "@types/node": "25.5.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vite": "^5.0.0"
  }
}
